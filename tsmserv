ansible-playbook -i inventory_cible_${STACK_NAME} config_sas.yml --extra-vars "target=$TYPE_SAS TYPE=$TYPE_SAS WORKLOAD=$WORKLOAD sas_version=$CONF_VERSION ACTION=$ACTION"

- name: Bloc config
  block:
    - name: Rechercher un script config spécifique à l'hôte
      ansible.builtin.find:
        paths: "{{ sas_tmp_dir }}"
        patterns: "{{ ansible_hostname }}-configfiles-installation_SASv{{ sas_version }}.sh"
        recurse: yes
      register: config_script

    - name: Exécuter le script config si présent
      ansible.builtin.shell: |
        /bin/bash "{{ item.path }}"
      loop: "{{ config_script.files }}"
      when: config_script.matched > 0

    - name: restart sas
      ansible.builtin.service:
        name: "sas.service"
        state: restarted
  when: ACTION == "config"

- name: Bloc install_config
  block:
    - name: Rechercher un script install_config spécifique à l'hôte
      ansible.builtin.find:
        paths: "{{ sas_tmp_dir }}"
        patterns: "{{ ansible_hostname }}-install-config-installation_SASv{{ sas_version }}.sh"
        recurse: yes
      register: install_config_script

    - name: Exécuter le script install_config si présent
      ansible.builtin.shell: |
        /bin/bash "{{ item.path }}"
      loop: "{{ install_config_script.files }}"
      when: install_config_script.matched > 0

    - name: restart sas
      ansible.builtin.service:
        name: "sas.service"
        state: restarted
  when: ACTION == "install_config"


